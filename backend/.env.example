# Application
APP_NAME=VeriTrust
APP_ENV=development
DEBUG=true

# Database
DATABASE_URL=postgresql://veritrust:veritrust_secret@localhost:5432/veritrust_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OTP
OTP_EXPIRE_MINUTES=5
OTP_RATE_LIMIT_SECONDS=60

# Email (SMTP)
# Gmail: use an App Password from https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@veritrust.in

# SMS - Twilio (recommended, free trial: https://www.twilio.com/try-twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Must be your Twilio-purchased number e.g. +14155552671 (NOT your personal mobile)
TWILIO_PHONE_NUMBER=

# SMS - Fast2SMS fallback (optional, paid)
FAST2SMS_API_KEY=
FAST2SMS_OTP_ID=

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
