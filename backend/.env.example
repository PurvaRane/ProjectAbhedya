# =============================================================================
# VeriTrust backend — environment template (SAFE TO COMMIT)
# Copy to backend/.env and fill in your values locally:
#   cp backend/.env.example backend/.env   (Linux/macOS)
#   copy backend\.env.example backend\.env (Windows)
#
# NEVER commit backend/.env — it is listed in .gitignore.
# Leave SMTP/Twilio blank for offline mode (OTPs print in backend logs).
# =============================================================================

# Application
APP_NAME=VeriTrust
APP_ENV=development
DEBUG=true

# Database (use port 5433 when using docker-compose postgres mapping)
DATABASE_URL=postgresql://veritrust:veritrust_secret@localhost:5433/veritrust_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — generate a random secret for local dev (do not use this string in production)
JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OTP
OTP_EXPIRE_MINUTES=5
OTP_RATE_LIMIT_SECONDS=60

# Email (SMTP) — optional; leave empty for offline OTP simulation
# Gmail: use an App Password from https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@veritrust.in

# SMS — Twilio (optional; leave empty for offline OTP simulation)
# https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164 format e.g. +14155552671 (Twilio-purchased number, NOT your personal mobile)
TWILIO_PHONE_NUMBER=

# SMS — Fast2SMS fallback (optional)
FAST2SMS_API_KEY=
FAST2SMS_OTP_ID=

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
